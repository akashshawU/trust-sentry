# ── AI Provider Keys ──────────────────────────────────────────────────────────
# At least one key is required to enable AI-powered evaluation.
# When no key is set the platform falls back to rule-based scoring (simulation mode).

# Groq — PRIMARY provider (llama-3.3-70b-versatile, 30 RPM free tier)
# Get your free key at https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — FALLBACK provider (gemini-1.5-flash, 15 RPM / 1 500 RPD free tier)
# Get your free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude — legacy / optional (not used in current evaluation chain)
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
